/-- Base case `n=2`. -/
theorem E33_le_wick_base_two : E33 2 ≤ wick 33 2 := by rw [E33_two, wick_thirtythree]; norm_num

/-- Base case `n=4`. -/
theorem E33_le_wick_base_four : E33 4 ≤ wick 33 4 := by rw [E33_four, wick_thirtythree]; norm_num

/-- The depth-33 char-0 Wick/Gaussian bound on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 11`. -/
theorem E33_le_wick (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 11 ≤ n) : E33 n ≤ wick 33 n := by
  rcases hn with rfl | hrest
  · exact E33_le_wick_base_two
  · rcases hrest with rfl | hrest
    · exact E33_le_wick_base_four
    · rcases hrest with rfl | hge
      · have h8 : (0 : ℤ) ≤ wick 33 8 - E33 8 := by
          rw [deficit_thirtythree]; norm_num
        linarith
      · have hpos := deficit_thirtythree_nonneg_from_11 n hge
        linarith

/-- The depth-33 char-0 Wick deficit is strictly positive on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 11`. -/
theorem deficit_thirtythree_pos (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 11 ≤ n) :
    0 < wick 33 n - E33 n := by
  rcases hn with rfl | hrest
  · rw [deficit_thirtythree]; norm_num
  · rcases hrest with rfl | hrest
    · rw [deficit_thirtythree]; norm_num
    · rcases hrest with rfl | hge
      · rw [deficit_thirtythree]; norm_num
      · have hu0 : (0 : ℤ) ≤ n - 11 := by linarith
        have hnpos : (0 : ℤ) < n := by linarith
        have hcert := deficit_thirtythree_factored_v n
        rw [hcert]
        positivity

end ProximityGap.Frontier.E33ClosedForm

