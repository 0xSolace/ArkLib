/-- The Wick leading term `(2r−1)‼·n^r`. -/
def wick (r : ℕ) (n : ℤ) : ℤ := (Nat.doubleFactorial (2 * r - 1) : ℤ) * n ^ r

@[simp] theorem wick_twentyeight (n : ℤ) : wick 28 n = 8687364368561751199826958100282265625 * n ^ 28 := by
  simp [wick, Nat.doubleFactorial]

