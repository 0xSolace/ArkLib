/-- Base case `n=2`. -/
theorem E28_le_wick_base_two : E28 2 ≤ wick 28 2 := by rw [E28_two, wick_twentyeight]; norm_num

/-- Base case `n=4`. -/
theorem E28_le_wick_base_four : E28 4 ≤ wick 28 4 := by rw [E28_four, wick_twentyeight]; norm_num

/-- The depth-28 char-0 Wick/Gaussian bound on the dyadic support range: `n = 2`,
`n = 4`, `n = 8`, or `n ≥ 9`. -/
theorem E28_le_wick (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 9 ≤ n) : E28 n ≤ wick 28 n := by
  rcases hn with rfl | hrest
  · exact E28_le_wick_base_two
  · rcases hrest with rfl | hrest
    · exact E28_le_wick_base_four
    · rcases hrest with rfl | hge
      · have h8 : (0 : ℤ) ≤ wick 28 8 - E28 8 := by
          rw [deficit_twentyeight]; norm_num
        linarith
      · have hpos := deficit_twentyeight_nonneg_from_9 n hge
        linarith

/-! ## The Wick cushion is strictly positive -/

/-- The depth-28 char-0 Wick deficit is strictly positive on the dyadic support range: `n = 2`,
`n = 4`, `n = 8`, or `n ≥ 9`. -/
theorem deficit_twentyeight_pos (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 9 ≤ n) :
    0 < wick 28 n - E28 n := by
  rcases hn with rfl | hrest
  · rw [deficit_twentyeight]; norm_num
  · rcases hrest with rfl | hrest
    · rw [deficit_twentyeight]; norm_num
    · rcases hrest with rfl | hge
      · rw [deficit_twentyeight]; norm_num
      · have hu0 : (0 : ℤ) ≤ n - 9 := by linarith
        have hnpos : (0 : ℤ) < n := by linarith
        have hcert := deficit_twentyeight_factored_v n
        rw [hcert]
        positivity

