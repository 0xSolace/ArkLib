/-- Base case `n=2`. -/
theorem E31_le_wick_base_two : E31 2 ≤ wick 31 2 := by rw [E31_two, wick_thirtyone]; norm_num

/-- Base case `n=4`. -/
theorem E31_le_wick_base_four : E31 4 ≤ wick 31 4 := by rw [E31_four, wick_thirtyone]; norm_num

/-- The depth-31 char-0 Wick/Gaussian bound on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 10`. -/
theorem E31_le_wick (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 10 ≤ n) : E31 n ≤ wick 31 n := by
  rcases hn with rfl | hrest
  · exact E31_le_wick_base_two
  · rcases hrest with rfl | hrest
    · exact E31_le_wick_base_four
    · rcases hrest with rfl | hge
      · have h8 : (0 : ℤ) ≤ wick 31 8 - E31 8 := by
          rw [deficit_thirtyone]; norm_num
        linarith
      · have hpos := deficit_thirtyone_nonneg_from_10 n hge
        linarith

/-- The depth-31 char-0 Wick deficit is strictly positive on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 10`. -/
theorem deficit_thirtyone_pos (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 10 ≤ n) :
    0 < wick 31 n - E31 n := by
  rcases hn with rfl | hrest
  · rw [deficit_thirtyone]; norm_num
  · rcases hrest with rfl | hrest
    · rw [deficit_thirtyone]; norm_num
    · rcases hrest with rfl | hge
      · rw [deficit_thirtyone]; norm_num
      · have hu0 : (0 : ℤ) ≤ n - 10 := by linarith
        have hnpos : (0 : ℤ) < n := by linarith
        have hcert := deficit_thirtyone_factored_v n
        rw [hcert]
        positivity

