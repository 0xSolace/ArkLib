/-- Base case `n=2`. -/
theorem E32_le_wick_base_two : E32 2 ≤ wick 32 2 := by rw [E32_two, wick_thirtytwo]; norm_num

/-- Base case `n=4`. -/
theorem E32_le_wick_base_four : E32 4 ≤ wick 32 4 := by rw [E32_four, wick_thirtytwo]; norm_num

/-- The depth-32 char-0 Wick/Gaussian bound on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 10`. -/
theorem E32_le_wick (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 10 ≤ n) : E32 n ≤ wick 32 n := by
  rcases hn with rfl | hrest
  · exact E32_le_wick_base_two
  · rcases hrest with rfl | hrest
    · exact E32_le_wick_base_four
    · rcases hrest with rfl | hge
      · have h8 : (0 : ℤ) ≤ wick 32 8 - E32 8 := by
          rw [deficit_thirtytwo]; norm_num
        linarith
      · have hpos := deficit_thirtytwo_nonneg_from_10 n hge
        linarith

/-- The depth-32 char-0 Wick deficit is strictly positive on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 10`. -/
theorem deficit_thirtytwo_pos (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 10 ≤ n) :
    0 < wick 32 n - E32 n := by
  rcases hn with rfl | hrest
  · rw [deficit_thirtytwo]; norm_num
  · rcases hrest with rfl | hrest
    · rw [deficit_thirtytwo]; norm_num
    · rcases hrest with rfl | hge
      · rw [deficit_thirtytwo]; norm_num
      · have hu0 : (0 : ℤ) ≤ n - 10 := by linarith
        have hnpos : (0 : ℤ) < n := by linarith
        have hcert := deficit_thirtytwo_factored_v n
        rw [hcert]
        positivity

