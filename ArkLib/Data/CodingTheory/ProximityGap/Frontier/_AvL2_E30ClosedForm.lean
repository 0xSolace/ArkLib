/-- Base case `n=2`. -/
theorem E30_le_wick_base_two : E30 2 ≤ wick 30 2 := by rw [E30_two, wick_thirty]; norm_num

/-- Base case `n=4`. -/
theorem E30_le_wick_base_four : E30 4 ≤ wick 30 4 := by rw [E30_four, wick_thirty]; norm_num

/-- The depth-30 char-0 Wick/Gaussian bound on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 10`. -/
theorem E30_le_wick (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 10 ≤ n) : E30 n ≤ wick 30 n := by
  rcases hn with rfl | hrest
  · exact E30_le_wick_base_two
  · rcases hrest with rfl | hrest
    · exact E30_le_wick_base_four
    · rcases hrest with rfl | hge
      · have h8 : (0 : ℤ) ≤ wick 30 8 - E30 8 := by
          rw [deficit_thirty]; norm_num
        linarith
      · have hpos := deficit_thirty_nonneg_from_10 n hge
        linarith

/-- The depth-30 char-0 Wick deficit is strictly positive on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 10`. -/
theorem deficit_thirty_pos (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 10 ≤ n) :
    0 < wick 30 n - E30 n := by
  rcases hn with rfl | hrest
  · rw [deficit_thirty]; norm_num
  · rcases hrest with rfl | hrest
    · rw [deficit_thirty]; norm_num
    · rcases hrest with rfl | hge
      · rw [deficit_thirty]; norm_num
      · have hu0 : (0 : ℤ) ≤ n - 10 := by linarith
        have hnpos : (0 : ℤ) < n := by linarith
        have hcert := deficit_thirty_factored_v n
        rw [hcert]
        positivity

