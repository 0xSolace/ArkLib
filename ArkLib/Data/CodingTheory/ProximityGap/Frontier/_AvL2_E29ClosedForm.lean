/-- Base case `n=2`. -/
theorem E29_le_wick_base_two : E29 2 ≤ wick 29 2 := by rw [E29_two, wick_twentynine]; norm_num

/-- Base case `n=4`. -/
theorem E29_le_wick_base_four : E29 4 ≤ wick 29 4 := by rw [E29_four, wick_twentynine]; norm_num

/-- The depth-29 char-0 Wick/Gaussian bound on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 10`. -/
theorem E29_le_wick (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 10 ≤ n) : E29 n ≤ wick 29 n := by
  rcases hn with rfl | hrest
  · exact E29_le_wick_base_two
  · rcases hrest with rfl | hrest
    · exact E29_le_wick_base_four
    · rcases hrest with rfl | hge
      · have h8 : (0 : ℤ) ≤ wick 29 8 - E29 8 := by
          rw [deficit_twentynine]; norm_num
        linarith
      · have hpos := deficit_twentynine_nonneg_from_10 n hge
        linarith

/-- The depth-29 char-0 Wick deficit is strictly positive on the dyadic support range: `n = 2`, `n = 4`, `n = 8`, or `n ≥ 10`. -/
theorem deficit_twentynine_pos (n : ℤ) (hn : n = 2 ∨ n = 4 ∨ n = 8 ∨ 10 ≤ n) :
    0 < wick 29 n - E29 n := by
  rcases hn with rfl | hrest
  · rw [deficit_twentynine]; norm_num
  · rcases hrest with rfl | hrest
    · rw [deficit_twentynine]; norm_num
    · rcases hrest with rfl | hge
      · rw [deficit_twentynine]; norm_num
      · have hu0 : (0 : ℤ) ≤ n - 10 := by linarith
        have hnpos : (0 : ℤ) < n := by linarith
        have hcert := deficit_twentynine_factored_v n
        rw [hcert]
        positivity

