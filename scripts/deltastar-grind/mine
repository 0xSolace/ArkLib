#!/usr/bin/env bash
# Œ¥*-mine ‚Äî ONE command to mine the Reed‚ÄìSolomon proximity prize.
#
# Like `solana-keygen grind`, but it hunts a DISPROOF of the proximity-gap conjecture
# (one counterexample = you win the $1M by disproving). Auto-builds + self-calibrates,
# then grinds. CPU by default (good to n‚âà28); uses GPU automatically if nvcc is present.
#
#   mine                 # just mine ‚Äî calibrate, then sweep the tower hunting a disproof
#   mine 32              # mine one size n=32
#   mine --max 44        # sweep up to n=44 (the brute-force frontier)
#   mine --shard 3/16    # your slice of a distributed pool (machine 3 of 16)
#   mine --help
#
# HONEST: a disproof (super-budget hit) WINS. A proof cannot be ground out (it needs new
# math ‚Äî the 25-yr BGK wall). And this is the proxy face (p‚âàn‚Å¥); brute force dies at n‚âà44.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUSTBIN="$HERE/../rust-pg/target/release/pg"
CUDABIN="$HERE/../cuda-pg/pg"
b=$'\033[1m'; d=$'\033[2m'; g=$'\033[32m'; r=$'\033[31m'; c=$'\033[36m'; y=$'\033[33m'; m=$'\033[35m'; x=$'\033[0m'

usage() { cat <<EOF
${b}Œ¥*-mine${x} ‚Äî one command to mine the RS proximity prize (hunt a disproof)

  ${b}mine${x}                 just mine: calibrate, then sweep the tower hunting a disproof
  ${b}mine N${x}               mine one size (e.g. ${b}mine 32${x})
  ${b}mine --live${x}          live dashboard ‚Äî watch it grind, rows fill in, disproof-hunt status
  ${b}mine --max M${x}         sweep n = 8,16,32‚Ä¶ up to M (default 32 on CPU, 44 on GPU)
  ${b}mine --shard i/N${x}     your slice of a distributed pool
  ${b}mine --help${x}

${d}WIN = a disproof (one super-budget hit, flagged loudly). A proof can't be ground out.
Proxy face (p‚âàn‚Å¥); brute wall at n‚âà44. CPU auto; GPU used if nvcc present.${x}
EOF
}

have() { command -v "$1" >/dev/null 2>&1; }

# build + pick engine (GPU if available, else CPU); echoes binary path
setup() {
  if have nvcc && { [ -x "$CUDABIN" ] || ( cd "$HERE/../cuda-pg" && make >/dev/null 2>&1 ); }; then echo "$CUDABIN"; return; fi
  [ -x "$RUSTBIN" ] || { have cargo || { echo "${r}need cargo or nvcc to build the engine${x}" >&2; exit 1; }; ( cd "$HERE/../rust-pg" && cargo build --release >/dev/null 2>&1 ); }
  echo "$RUSTBIN"
}

# self-calibrate against the ground-truth oracle; exits if the engine is wrong
calibrate() {
  local bin=$1
  local o8 o16; o8=$("$bin" 8 2 2>/dev/null); o16=$("$bin" 16 4 2>/dev/null)
  if grep -q "s\*=5" <<<"$o8" && grep -qE "s=6 .*maxI=89" <<<"$o16" && grep -q "s\*=7" <<<"$o16"; then
    printf '%s\n' "${g}‚úì calibrated${x} ${d}(engine reproduces the known answers n=8‚Üís*=5, n=16‚ÜímaxI=89)${x}"
  else printf '%s\n' "${r}‚úó calibration FAILED ‚Äî engine is buggy, not mining.${x}"; exit 1; fi
}

# mine one size: grind the cascade, flag a disproof, print the honest lean. sets global LAST_W.
LAST_W=""
mine_one() {
  local bin=$1 n=$2 k=$(( $2 / 4 )) out; LAST_W="?"
  out=$("$bin" "$n" "$k" 2>/dev/null) || { printf '  %s\n' "${y}n=$n did not finish (compute wall ‚Äî try GPU or smaller n)${x}"; return 1; }
  local sstar dstar defect casc w
  sstar=$(grep -oE 's\*=[0-9]+' <<<"$out" | head -1 | cut -d= -f2)
  dstar=$(grep -oE 'delta\*=[0-9.]+' <<<"$out" | head -1 | cut -d= -f2)
  defect=$(grep -oE 'defect\(s\*-k\)/n=[0-9.]+' <<<"$out" | head -1 | cut -d= -f2)
  casc=$(grep -E '^\s+s=' <<<"$out" | sed -E 's/^\s+s=([0-9]+).*maxI=([0-9]+).*/\1:\2/' | tr '\n' ' ')
  w=$(grep -cE 'maxI=89 ' <<<"$out" || true); LAST_W=$w   # plateau width = #(89 value), œÅ=1/4 tower
  # DISPROOF check: cascade never bound under budget?  (s* missing = it broke through capacity)
  if [ -z "$sstar" ]; then
    printf '  %s n=%-3s %s\n' "${r}${b}‚Äº DISPROOF CANDIDATE${x}" "$n" "${r}cascade never bound under budget ‚Äî VERIFY + report to #444 NOW${x}"
    return 0
  fi
  printf '  n=%-3s  cascade[%s] Œ¥*=%s  w=%s  ' "$n" "${casc%% }" "$dstar" "$w"
  if [ "$n" -lt 16 ]; then printf '%s\n' "${d}(calibration size ‚Äî too small to lean)${x}"
  elif awk "BEGIN{exit !($defect >= 0.30)}" 2>/dev/null; then printf '%s\n' "${y}defect/n=$defect (leans FAILS ‚Äî watch √ó2)${x}"
  else printf '%s\n' "${g}defect/n=$defect (leans HOLDS)${x}"; fi
}

# ‚îÄ‚îÄ live dashboard (--live): animated spinner per size, rows fill in, disproof-hunt status ‚îÄ‚îÄ
SPIN='‚Ýã‚Ýô‚Ýπ‚Ý∏‚Ýº‚Ý¥‚Ý¶‚Ýß‚Ýá‚Ýè'
spinner() {  # $1=pid  $2=label
  local i=0
  while kill -0 "$1" 2>/dev/null; do printf "\r   ${c}%s${x} %s" "${SPIN:i++%10:1}" "$2"; sleep 0.08; done
  printf '\r\033[K'
}
live_sweep() {  # $1=bin ; rest=sizes
  local bin=$1; shift
  printf '%s\n' "${b}${m}  ‚õè  Œ¥*-MINE ‚Äî live disproof hunt${x}"
  printf '   %s\n' "${d}$(printf '‚îÄ%.0s' $(seq 1 58))${x}"
  printf '   ${b}%-4s %-26s %-8s %-4s %s${x}\n' "n" "cascade  (s:maxI)" "Œ¥*" "m*" "status"
  printf '   %s\n' "${d}$(printf '‚îÄ%.0s' $(seq 1 58))${x}"
  local ws="" tmp; tmp=$(mktemp)
  local n
  for n in "$@"; do
    local k=$(( n/4 ))
    "$bin" "$n" "$k" >"$tmp" 2>/dev/null & local pid=$!
    spinner "$pid" "grinding n=$n (k=$k) ‚Äî hunting a super-budget hit‚Ä¶"
    wait "$pid" 2>/dev/null || true
    local casc dstar mstar w status
    casc=$(grep -E '^\s+s=' "$tmp" | sed -E 's/^\s+s=([0-9]+).*maxI=([0-9]+).*/\1:\2/' | tr '\n' ' ')
    dstar=$(grep -oE 'delta\*=[0-9.]+' "$tmp" | head -1 | cut -d= -f2)
    mstar=$(grep -oE 's\*-k=[0-9]+' "$tmp" | head -1 | cut -d= -f2)
    w=$(grep -cE 'maxI=89 ' "$tmp" 2>/dev/null || echo 0)
    if [ -n "$dstar" ]; then status="${g}‚úì binds${x}"; else status="${r}${b}‚Äº DISPROOF ‚Äî verify+report #444${x}"; fi
    printf '   %-4s %-26s %-8s %-4s %b\n' "$n" "${casc%% }" "${dstar:-‚Äî}" "${mstar:-‚Äî}" "$status"
    ws="$ws $w"
  done
  rm -f "$tmp"
  echo
  printf '   ${d}plateau widths w(n):${x}%s   ${d}(0,1,2,‚Ä¶ ; √ó2 jump = disproof signal)${x}\n' "$ws"
  printf '   ${g}üîç hunt complete: no disproof at these sizes ‚Äî conjecture stands here.${x}\n'
  printf '   ${y}honest: proxy face (p‚âàn‚Å¥); a real win = a disproof at reachable n, or the (uncomputable) proof.${x}\n'
}

# ‚îÄ‚îÄ parse args ‚îÄ‚îÄ
MAX=""; ONE=""; SHARD=""; LIVE=""
while [ $# -gt 0 ]; do case "$1" in
  -h|--help|help) usage; exit 0 ;;
  --live) LIVE=1; shift ;;
  --max) MAX="$2"; shift 2 ;;
  --shard) SHARD="$2"; shift 2 ;;
  [0-9]*) ONE="$1"; shift ;;
  *) echo "${r}unknown arg: $1${x}"; usage; exit 1 ;;
esac; done

printf '%s\n' "${b}${m}‚õè  Œ¥*-mine${x} ‚Äî hunting a disproof of the proximity-gap conjecture"
BIN=$(setup)
NAME=$([ "$BIN" = "$CUDABIN" ] && echo "GPU" || echo "CPU")
printf '%s\n' "${d}engine: $NAME${x}"
calibrate "$BIN"
echo

if [ -n "$LIVE" ]; then
  # fast CPU-reachable sweep so the spinner is visible and nothing hangs (n=32+ is GPU territory)
  sizes=(8 12 16 20 24 28); [ -n "$ONE" ] && sizes=("$ONE")
  live_sweep "$BIN" "${sizes[@]}"
  exit 0
fi

if [ -n "$SHARD" ]; then
  i=${SHARD%/*}; N=${SHARD#*/}; n=${ONE:-32}; k=$(( n/4 ))
  span=$(( (n + N - 1) / N )); a0=$(( i*span )); a1=$(( a0+span ))
  printf '%s\n' "${b}pool share $i/$N${x} ‚Äî n=$n directions a‚àà[$a0,$a1). Emitting SHARD lines for the coordinator:"
  for (( a=a0; a<a1 && a<n; a++ )); do for (( bb=k; bb<n; bb++ )); do [ "$a" = "$bb" ] && continue
    "$RUSTBIN" "$n" "$k" "$a" "$bb" 2>/dev/null | grep -E '^\s+s=' | sed -E "s/^\s+s=([0-9]+).*[^a-zA-Z]I=([0-9]+).*/SHARD $n $k $a $bb \1 \2/" || true
  done; done
  exit 0
fi

if [ -n "$ONE" ]; then
  mine_one "$BIN" "$ONE"
  exit 0
fi

# default: sweep the tower, hunting a disproof, tracking the w(n) growth law
[ -z "$MAX" ] && { [ "$NAME" = GPU ] && MAX=44 || MAX=16; }
printf '%s\n' "${b}sweeping the 2-power tower (hunting a disproof; tracking w(n))${x}  ${d}max n=$MAX${x}"
ws=""
n=8
while [ "$n" -le "$MAX" ]; do
  mine_one "$BIN" "$n"; ws="$ws $LAST_W"; n=$(( n*2 ))
done
echo
printf '%s\n' "${b}plateau widths w(n):${x}${ws}  ${d}(recorded full tower: 0,1,2,? ‚Äî w(64)=3 additive‚ÜíHOLDS, 4 √ó2‚ÜíFAILS)${x}"
printf '%s\n' "${g}no disproof found at these sizes${x} ${d}‚Äî the conjecture still stands here; push to larger n (GPU) to keep hunting.${x}"
printf '%s\n' "${y}honest: proxy face (p‚âàn‚Å¥); a real win needs a disproof at reachable n, or the (uncomputable) proof.${x}"
