#!/usr/bin/env bash
# δ*-grind — a distributed grinder for the Reed–Solomon proximity-gap frontier.
#
# Like `solana-keygen grind`, but instead of hunting a vanity key prefix it grinds the
# over-determined far-line incidence cascade D*_n(m) of the smooth-domain RS proximity gap,
# maximizing over directions at each agreement depth. Wraps two ALREADY-VALIDATED kernels:
#   CPU: scripts/rust-pg  (Rust + rayon)        — auto, builds with cargo
#   GPU: scripts/cuda-pg  (CUDA, pg.cu)         — used when nvcc is present (≈400–2000× faster)
#
# ┌─ HONEST SCOPE — read this, it is the whole point ────────────────────────────────────┐
# │ This tool GRINDS EVIDENCE and HUNTS A DISPROOF. It does NOT and CANNOT prove the prize.│
# │  1. Brute force dies at n≈44 (the C(n,s) term explodes). It cannot reach asymptotic n, │
# │     so it can never *settle* additive-vs-multiplicative — only add data points.        │
# │  2. It computes the PROXY face (prime p≈n⁴), not the real cryptographic-p BGK wall      │
# │     M(μ_n) ≤ C√(n·log(p/n)). Even infinite compute decides the proxy, not the $1M.     │
# │  3. A grinder can DISPROVE (find one super-budget/×2-doubling counterexample) but can  │
# │     never PROVE the conjecture. This is folding@home for a frontier, not a lottery.    │
# └────────────────────────────────────────────────────────────────────────────────────────┘
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUSTDIR="$HERE/../rust-pg"
CUDADIR="$HERE/../cuda-pg"
RUSTBIN="$RUSTDIR/target/release/pg"
CUDABIN="$CUDADIR/pg"

c_bold=$'\033[1m'; c_dim=$'\033[2m'; c_grn=$'\033[32m'; c_red=$'\033[31m'
c_cyn=$'\033[36m'; c_yel=$'\033[33m'; c_rst=$'\033[0m'
say()  { printf '%s\n' "$*"; }
hdr()  { printf '%s\n' "${c_bold}${c_cyn}$*${c_rst}"; }
ok()   { printf '%s\n' "${c_grn}✓ $*${c_rst}"; }
warn() { printf '%s\n' "${c_yel}⚠ $*${c_rst}"; }
err()  { printf '%s\n' "${c_red}✗ $*${c_rst}"; }

have() { command -v "$1" >/dev/null 2>&1; }

build_cpu() {
  [ -x "$RUSTBIN" ] && return 0
  have cargo || { err "cargo (Rust) not found — install rustup to build the CPU kernel"; return 1; }
  say "${c_dim}building CPU kernel (rust-pg)…${c_rst}"
  ( cd "$RUSTDIR" && cargo build --release >/dev/null 2>&1 ) && [ -x "$RUSTBIN" ]
}
build_gpu() {
  have nvcc || return 1
  [ -x "$CUDABIN" ] && return 0
  say "${c_dim}building GPU kernel (cuda-pg)…${c_rst}"
  ( cd "$CUDADIR" && make >/dev/null 2>&1 ) && [ -x "$CUDABIN" ]
}

# pick the engine: GPU if nvcc+built, else CPU. echoes the binary path.
engine() {
  if build_gpu 2>/dev/null; then echo "$CUDABIN"; return 0; fi
  build_cpu >/dev/null 2>&1 || { err "no usable kernel (need cargo or nvcc)"; exit 1; }
  echo "$RUSTBIN"
}
engine_name() { [ "$1" = "$CUDABIN" ] && echo "GPU/cuda-pg" || echo "CPU/rust-pg"; }

# crude feasibility guard: log2(C(n, n/4+ a few)) — refuse silly brute forces with honesty.
feasible_note() {
  local n=$1
  if   [ "$n" -le 24 ]; then echo "CPU-feasible (seconds–minutes)";
  elif [ "$n" -le 32 ]; then echo "CPU-slow (minutes–hours); GPU recommended";
  elif [ "$n" -le 44 ]; then echo "GPU-only (brute-force frontier)";
  else echo "BEYOND BRUTE FORCE (n>44: C(n,s) explodes — needs the closed form, not this tool)"; fi
}

# ── the ground-truth calibration oracle ─────────────────────────────────────────────
# These exact values are the correctness anchor. A kernel that does not reproduce them
# is buggy and its big-n output is meaningless. validate runs before any trusted report.
validate() {
  hdr "δ*-grind validate — calibration gate (ground-truth oracle)"
  local bin; bin=$(engine); say "engine: $(engine_name "$bin")"
  local fail=0
  # n=8 k=2: s*=5, delta*=0.3750 ; n=16 k=4: s=6 maxI=89, s*=7, delta*=0.5625
  local o8 o16
  o8=$("$bin" 8 2 2>/dev/null)
  o16=$("$bin" 16 4 2>/dev/null)
  if grep -q "s\*=5" <<<"$o8" && grep -q "delta\*=0.3750" <<<"$o8"; then ok "n=8  k=2 → s*=5, δ*=0.3750"; else err "n=8 FAILED"; fail=1; fi
  if grep -qE "s=6 .*maxI=89" <<<"$o16" && grep -q "s\*=7" <<<"$o16" && grep -q "delta\*=0.5625" <<<"$o16"; then
    ok "n=16 k=4 → s=6 maxI=89 (the 1+11·8 plateau value), s*=7, δ*=0.5625"
  else err "n=16 FAILED"; fail=1; fi
  echo
  if [ "$fail" = 0 ]; then ok "CALIBRATED — this kernel reproduces the ground truth. Big-n output is trustworthy."; return 0
  else err "VALIDATION FAILED — do NOT trust this kernel's output."; return 1; fi
}

# extract the per-s cascade as "s:maxI" and the binding line
cascade() { grep -E '^\s+s=' | sed -E 's/^\s+s=([0-9]+).*maxI=([0-9]+).*/\1:\2/'; }

# ── grind one cascade ───────────────────────────────────────────────────────────────
run_one() {
  local n=$1 k=${2:-} ; [ -z "$k" ] && k=$(( n / 4 ))   # rho=1/4 default
  hdr "δ*-grind run — n=$n k=$k (ρ=1/4)"
  say "${c_dim}feasibility: $(feasible_note "$n")${c_rst}"
  local bin; bin=$(engine); say "engine: $(engine_name "$bin")"; echo
  "$bin" "$n" "$k"
}

# ── grind the 2-power tower + read off the plateau-width growth law ───────────────────
tower() {
  local maxn=${1:-32}
  hdr "δ*-grind tower — the 2-power tower (the additive-vs-multiplicative decider)"
  say "${c_dim}w(n) = run-length of the constant pre-binding value 89 in the worst-dir cascade.${c_rst}"
  say "${c_dim}additive  w(2n)=w(n)+c → m*=O(log n) → prize HOLDS direction${c_rst}"
  say "${c_dim}mult.     w(2n)=2w(n)  → m* linear   → prize FAILS direction${c_rst}"
  say "${c_dim}recorded: w=0,1,2 at n=8,16,32 ; decider = w(64) ∈ {3 additive, 4 mult}${c_rst}"
  echo
  local bin; bin=$(engine)
  printf '%6s  %-30s  %6s\n' "n" "worst-dir cascade (s:maxI)" "δ*"
  local n=8
  while [ "$n" -le "$maxn" ]; do
    local k=$(( n / 4 ))
    say "${c_dim}grinding n=$n ($(feasible_note "$n"))…${c_rst}"
    local out casc ds
    out=$("$bin" "$n" "$k" 2>/dev/null) || { warn "n=$n did not complete (compute wall) — stopping"; break; }
    casc=$(printf '%s' "$out" | cascade | tr '\n' ' ')
    ds=$(printf '%s' "$out" | grep -oE 'delta\*=[0-9.]+' | head -1)
    printf '%6s  %-30s  %6s\n' "$n" "$casc" "${ds#delta*=}"
    n=$(( n * 2 ))
  done
  echo
  warn "Honest read: this decides the PROXY face (p≈n⁴), not the real p-dependent BGK wall."
}

# ── disproof hunt: flag any super-budget anomaly / ×2 doubling (Shaw's 'we can disprove it') ──
hunt() {
  local n=$1 k=${2:-} ; [ -z "$k" ] && k=$(( n / 4 ))
  hdr "δ*-grind hunt — disproof mode (n=$n k=$k)"
  say "${c_dim}A disproof = the cascade FAILS to bind (maxI stays > budget into the window interior),${c_rst}"
  say "${c_dim}or the plateau width doubles (w(2n)=2w(n)). One real counterexample = decisive.${c_rst}"
  local bin; bin=$(engine); local out
  out=$("$bin" "$n" "$k" 2>/dev/null) || { err "did not complete (compute wall)"; exit 1; }
  printf '%s\n' "$out"
  local budget=$n
  local sstar; sstar=$(printf '%s' "$out" | grep -oE 's\*=[0-9]+' | head -1)
  local cap_defect; cap_defect=$(printf '%s' "$out" | grep -oE 'defect\(s\*-k\)/n=[0-9.]+' | head -1)
  echo
  # honest heuristic flag: if the binding defect/n is large (m* big relative to n) it leans FAILS
  if [ -n "$cap_defect" ]; then
    local d=${cap_defect#defect(s*-k)/n=}
    # leans-fails if defect/n stays >= ~0.30 (Johnson-stuck); leans-holds if it shrinks
    if awk "BEGIN{exit !($d >= 0.30)}"; then
      warn "defect/n = $d : LEANS toward prize-FAILS (m* large rel. to n) — note + cross-check at 2n"
    else
      ok "defect/n = $d : leans toward prize-HOLDS (m* sub-linear) — consistent with pow2dip"
    fi
  fi
  warn "No single n is decisive. Run the tower and compare w(n) vs w(2n). Report anomalies to #444."
}

# ── distribution: a direction-shard work unit (uses rust-pg single-direction mode) ────
# Computes incidence for directions a in [astart,aend) (all valid b), prints per-(s) local max.
# A coordinator takes the max over shards. This is how laptops + servers split one big n.
shard() {
  local n=$1 k=$2 astart=$3 aend=$4
  hdr "δ*-grind shard — n=$n k=$k directions a∈[$astart,$aend)"
  build_cpu >/dev/null 2>&1 || { err "shard mode uses the CPU single-direction kernel (needs cargo)"; exit 1; }
  say "${c_dim}per-direction incidence; coordinator maxes over shards. Emit results as 'SHARD n k a b s maxI'.${c_rst}"
  local a b
  for (( a=astart; a<aend && a<n; a++ )); do
    for (( b=k; b<n; b++ )); do
      [ "$a" = "$b" ] && continue
      "$RUSTBIN" "$n" "$k" "$a" "$b" 2>/dev/null | grep -E '^\s+s=' \
        | sed -E "s/^\s+s=([0-9]+).*[^a-zA-Z]I=([0-9]+).*/SHARD $n $k $a $b \1 \2/" || true
    done
  done
}

doctor() {
  hdr "δ*-grind doctor — toolchain & kernels"
  printf 'cores            : %s\n' "$(nproc 2>/dev/null || echo '?')"
  if have cargo; then ok "cargo present (CPU kernel buildable)"; else warn "cargo missing (no CPU kernel)"; fi
  if have nvcc;  then ok "nvcc present (GPU kernel buildable — ~400–2000× faster)"; else say "${c_dim}· nvcc absent (CPU-only; fine for n≤~28)${c_rst}"; fi
  say "${c_dim}building available kernels…${c_rst}"
  build_cpu >/dev/null 2>&1 && ok "CPU kernel ready: $RUSTBIN" || warn "CPU kernel not built"
  build_gpu 2>/dev/null   && ok "GPU kernel ready: $CUDABIN" || say "${c_dim}· GPU kernel not built${c_rst}"
  echo; say "Next: ${c_bold}grind validate${c_rst} (calibration gate), then ${c_bold}grind tower${c_rst}."
}

usage() {
  cat <<EOF
${c_bold}δ*-grind${c_rst} — distributed grinder for the RS proximity-gap frontier (CPU + GPU)

  ${c_bold}grind doctor${c_rst}                  detect toolchain, build CPU/GPU kernels
  ${c_bold}grind validate${c_rst}                calibration gate (must pass before trusting output)
  ${c_bold}grind run  N [K]${c_rst}              grind one cascade  (K defaults to N/4, ρ=1/4)
  ${c_bold}grind tower [MAXN]${c_rst}            grind the 2-power tower, show the w(n) growth law
  ${c_bold}grind hunt N [K]${c_rst}              disproof mode — flag super-budget / ×2 anomalies
  ${c_bold}grind shard N K A0 A1${c_rst}         a distributable work unit (directions a∈[A0,A1))

${c_dim}HONEST SCOPE: grinds EVIDENCE + hunts a DISPROOF on the proxy face (p≈n⁴). Brute force
dies at n≈44. It cannot PROVE the conjecture — only disprove it or add data. Not a lottery.${c_rst}
EOF
}

cmd="${1:-}"; shift || true
case "$cmd" in
  doctor)   doctor ;;
  validate) validate ;;
  run)      [ $# -ge 1 ] || { usage; exit 1; }; run_one "$@" ;;
  tower)    tower "$@" ;;
  hunt)     [ $# -ge 1 ] || { usage; exit 1; }; hunt "$@" ;;
  shard)    [ $# -ge 4 ] || { usage; exit 1; }; shard "$@" ;;
  ""|-h|--help|help) usage ;;
  *) err "unknown command: $cmd"; echo; usage; exit 1 ;;
esac
