#!/usr/bin/env python3
"""
aggregate — the coordinator side of the δ*-mine crowd hunt ("folding@home for the disproof").

Each contributor runs a direction-shard:  ./mine --shard i/N        (machine i of N)
which emits lines:  SHARD n k a b s maxI
Pipe ALL contributors' SHARD lines into this script (cat shard-*.txt | ./aggregate). It assembles
the worst-direction cascade D*_n(s) = max over directions, finds the binding depth s*, and — the
whole point — flags a DISPROOF if a cascade never binds under budget (= a counterexample = a win).

Pure stdlib. No deps. Reads stdin or file args.
"""
import sys, re
from collections import defaultdict

def main():
    lines = []
    if len(sys.argv) > 1:
        for fn in sys.argv[1:]:
            with open(fn) as f: lines += f.readlines()
    else:
        lines = sys.stdin.readlines()

    # max maxI per (n, k, s) across all shards; track the argmax direction
    best = defaultdict(lambda: (-1, None))   # (n,k,s) -> (maxI, (a,b))
    seen_nk = set()
    pat = re.compile(r'^\s*SHARD\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+)\s*$')
    for ln in lines:
        m = pat.match(ln)
        if not m: continue
        n, k, a, b, s, mi = map(int, m.groups())
        seen_nk.add((n, k))
        if mi > best[(n, k, s)][0]:
            best[(n, k, s)] = (mi, (a, b))

    if not seen_nk:
        print("no SHARD lines found. Contributors emit them via:  ./mine --shard i/N")
        return

    for (n, k) in sorted(seen_nk):
        budget = n  # the prize budget is ~n (q*eps* ≈ n)
        ss = sorted(s for (nn, kk, s) in best if (nn, kk) == (n, k))
        print(f"\n=== n={n} k={k}  (budget = {budget}) ===")
        sstar = None
        for s in ss:
            mi, dir_ = best[(n, k, s)]
            good = mi <= budget
            tag = "GOOD (binds)" if good else "bad"
            print(f"  s={s} (depth {s-k}): maxI={mi} @ dir{dir_}  {tag}")
            if good and sstar is None:
                sstar = s
        if sstar is not None:
            dstar = (n - sstar) / n
            print(f"  => s*={sstar}, δ*={dstar:.4f}  — binds (no disproof at this n)")
        else:
            print(f"  => ‼‼ NO s* — the cascade NEVER bound under budget. POTENTIAL DISPROOF at n={n}.")
            print(f"     VERIFY: re-run the winning direction at a 2nd prime; pin (a,b); report PRIVATELY")
            print(f"     to #444 + affected teams before any public post. Claim only what's reproduced.")

if __name__ == "__main__":
    main()
